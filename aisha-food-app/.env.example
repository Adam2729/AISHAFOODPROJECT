# Required. The app does not silently fall back to localhost or a dead production host.
# Set both the launch environment and the matching backend URL explicitly.

# Local development example
EXPO_PUBLIC_LAUNCH_ENV=local
EXPO_PUBLIC_API_URL=https://api.oranjeeats.com

# Optional legacy alias for older Expo tooling
API_BASE_URL=https://api.oranjeeats.com

# Optional support WhatsApp line used by Home / Checkout / Tracking / Profile.
# Use E.164 format, for example +22370000000.
# You can set one shared number or market-specific numbers.
# EXPO_PUBLIC_SUPPORT_WHATSAPP_NUMBER=+447490493787
# EXPO_PUBLIC_SUPPORT_WHATSAPP_NUMBER_ML=+22370000000
# EXPO_PUBLIC_SUPPORT_WHATSAPP_NUMBER_DO=+18095550000

# Preview / staging example
# EXPO_PUBLIC_LAUNCH_ENV=preview
# EXPO_PUBLIC_API_URL=https://preview-api.your-live-host.com

# Production example
# EXPO_PUBLIC_LAUNCH_ENV=production
# EXPO_PUBLIC_API_URL=https://api.your-live-host.com

# Notes
# - Use `local` only for a backend reachable from the device or emulator.
# - Use `preview` or `production` only with a public HTTPS backend.
# - Run `npm run validate:launch:env` before EAS builds.
