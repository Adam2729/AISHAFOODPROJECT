{
  "name": "aisha-food-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "check:phase13": "tsc --noEmit",
    "validate:launch:env": "node scripts/validateDrBuild.js",
    "validate:launch": "npm run typecheck && npm run validate:launch:env",
    "validate:dr:env": "npm run validate:launch:env",
    "validate:dr": "npm run validate:launch",
    "pilot:check": "npm run typecheck && npm run validate:launch:env && node scripts/pilotCheck.js",
    "eas:build:android:preview": "npx eas-cli build --platform android --profile preview",
    "eas:build:android:production": "npx eas-cli build --platform android --profile production",
    "eas:submit:android": "npx eas-cli submit --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.15.1",
    "@react-navigation/native": "^7.1.30",
    "@react-navigation/native-stack": "^7.13.0",
    "expo": "~54.0.33",
    "expo-linking": "~8.0.11",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0"
  },
  "private": true,
  "devDependencies": {
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
