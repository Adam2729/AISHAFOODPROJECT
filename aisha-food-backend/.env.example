# Aisha Food backend environment template
# Current launch market: Bamako, Mali
# Dominican Republic remains supported with the same codebase and delivery models.
#
# Notes:
# - Use production secrets in production. Do not reuse local values.
# - Set launch config explicitly. Do not rely on hidden dev defaults for production.
# - Both delivery models remain supported: self_delivery and platform_driver.

# Core runtime
MONGODB_URI="mongodb+srv://<user>:<pass>@<cluster>/<db>"
ADMIN_KEY="replace-with-long-admin-key"
JWT_SECRET="replace-with-strong-random-secret"
DRIVER_JWT_SECRET="replace-with-strong-random-secret"
STATEMENT_SIGNING_SECRET="replace-with-strong-random-secret"
PII_HASH_SECRET="replace-with-strong-random-secret"
CRON_SECRET="replace-with-strong-random-secret"
GOOGLE_MAPS_API_KEY=""

# Public host / frontend alignment
PUBLIC_API_BASE_URL=""
PUBLIC_API_ALLOWED_ORIGINS=""

# Launch market defaults: Bamako
LAUNCH_CITY_CODE="BKO"
MULTICITY_ENABLE_BAMAKO="true"
BASE_LOCATION_LAT="12.6392"
BASE_LOCATION_LNG="-8.0029"
BAMAKO_BASE_LAT="12.6392"
BAMAKO_BASE_LNG="-8.0029"
MAX_RADIUS_KM="8"

# Support contact
# Required before production go-live. Leave blank in source control and inject per environment.
# E.164 format example: +22370000000
SUPPORT_WHATSAPP_E164="00447424088519"
SUPPORT_WHATSAPP_DEFAULT_TEXT="Bonjour, j'ai besoin d'aide pour ma commande."

# Optional email delivery
# Leave blank for local development. In non-production, missing SMTP config logs emails to the console.

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="myshops2729@gmail.com"
SMTP_PASS="foyi rfzu ixbj pama"
SMTP_POOL="true"
EMAIL_FROM="Aisha food <myshops2729@gmail.com>"

# Safety switches
MAINTENANCE_MODE="false"
# Local or UK-based development only. Production must keep this false.
DEV_ALLOW_ORDER_LOCATION_BYPASS="false"
ALLOW_SEED="false"
ALLOW_ADMIN_PAY_DISABLED_CITY="false"

# Financial defaults
COMMISSION_RATE_DEFAULT="0.08"
SUBSCRIPTION_MONTHLY_RDP="1500"
TRIAL_DAYS="90"
GRACE_DAYS="14"
DRIVER_LINK_TTL_HOURS="24"
PII_PHONE_RETENTION_DAYS="30"

# Growth defaults
REFERRALS_ENABLED="false"
REFERRAL_NEW_CUSTOMER_BONUS_RDP="50"
REFERRAL_REFERRER_BONUS_RDP="50"
PROMO_MAX_PERCENT="50"
PROMO_MAX_FIXED_RDP="500"
PROMO_CODE_MAX_LEN="24"

# Dominican Republic compatibility example
# LAUNCH_CITY_CODE="SDQ"
# BASE_LOCATION_LAT="18.4861"
# BASE_LOCATION_LNG="-69.9312"
# SUPPORT_WHATSAPP_DEFAULT_TEXT="Hola, necesito ayuda con mi pedido."

# Reference values only. Do not load directly in code.
# PROD_MONGODB_URI="mongodb+srv://<user>:<pass>@prod-cluster/aisha_food_prod"
# STAGING_MONGODB_URI="mongodb+srv://<user>:<pass>@staging-cluster/aisha_food_staging"
